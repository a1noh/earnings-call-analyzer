# Copy this file to `.env` and fill in the values. `.env` is gitignored.
#
# 1) ANTHROPIC_API_KEY — from https://console.anthropic.com/ (Settings -> API Keys).
#    Powers the LangGraph analysis agent and the eval judge.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2) FMP_API_KEY — free key from https://site.financialmodelingprep.com/developer/docs
#    The free tier is fine. Transcript bodies are often gated on free; when they
#    are, the app automatically falls back to SEC EDGAR (see README).
FMP_API_KEY=your_free_fmp_key_here

# 3) SEC_USER_AGENT — SEC EDGAR requires a contact User-Agent on every request.
#    No signup needed. Use "AppName your-email@example.com".
SEC_USER_AGENT=EarningsCallAnalyzer your-email@example.com

# 4) APP_PASSWORD — optional. If set, the app shows a password gate before anyone
#    can use it (protects your Anthropic credits on a public deploy). Leave empty
#    or unset to run without a login (fine for local dev). On Streamlit Community
#    Cloud, set this in the app's Secrets instead of here.
APP_PASSWORD=
